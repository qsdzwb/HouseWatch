<view class="container">
  <!-- 楼盘选择器 -->
  <view class="card" style="padding:10px 16px;">
    <picker mode="selector" range="{{projects}}" range-key="name" bindchange="onProjectChange">
      <view class="flex-between">
        <view style="font-size:15px;font-weight:600;" class="project-name">{{currentProjectName}}</view>
        <view style="font-size:13px;color:#1989FA;">切换 ▼</view>
      </view>
    </picker>
  </view>

  <!-- 顶部统计卡片 -->
  <view class="card">
    <view class="flex-between">
      <view class="card-title" style="margin-bottom:0;">成交变化</view>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view style="font-size:13px;color:#1989FA;">
          <block wx:if="{{date && date !== 'undefined' && date !== 'null'}}">{{date}}</block>
          <block wx:else>最新</block>
          ▼
        </view>
      </picker>
    </view>
    <view style="display:flex;gap:16px;margin-top:8px;font-size:13px;" wx:if="{{summary}}">
      <view>成交 <text class="text-red" style="font-weight:600;">{{summary.newSales || 0}}</text> 套</view>
      <view wx:if="{{summary.avgPriceDisplay}}">均价 <text style="color:#FF6600;font-weight:600;">{{summary.avgPriceDisplay}}</text></view>
    </view>
  </view>

  <!-- 成交数量折线图（可点击） -->
  <view class="card" wx:if="{{trend.length > 0}}">
    <view class="card-title">日成交数量</view>
    <canvas canvas-id="countChart" id="countChart"
            style="width:100%;height:220px;"
            bindtap="onChartTap" data-chart="count"></canvas>
  </view>

  <!-- 成交均价折线图（可点击） -->
  <view class="card" wx:if="{{priceTrend.length > 0}}">
    <view class="card-title">日成交均价（万元/㎡）</view>
    <canvas canvas-id="priceChart" id="priceChart"
            style="width:100%;height:220px;"
            bindtap="onChartTap" data-chart="price"></canvas>
  </view>

  <!-- 变化列表 -->
  <block wx:for="{{list}}" wx:key="id">
    <view class="change-card">
      <view style="display:flex;justify-content:space-between;align-items:center;">
        <view>
          <text class="change-tag new-sale" wx:if="{{item.change_type === 'new_sale'}}">成交</text>
          <text class="change-tag status-change" wx:else>变更</text>
        </view>
        <view class="text-gray" style="font-size:11px;">{{item.change_date || ''}}</view>
      </view>
      <view class="change-house">{{item.project_name || ''}} {{item.building_name || ''}} {{item.room_no || ''}}</view>
      <view class="change-detail">
        {{item.old_status || ''}} → {{item.new_status || ''}}
        <text wx:if="{{item.price_display}}" style="color:#FF6600;margin-left:8px;">{{item.price_display}}</text>
      </view>
    </view>
  </block>

  <view class="empty" wx:if="{{!list.length && !loading}}">
    <view wx:if="{{loadError}}" style="color:#E74C3C;">{{loadError}}</view>
    <view wx:else>暂无变化记录</view>
  </view>
  <view class="load-more" wx:if="{{loading}}">加载中...</view>
  <view class="load-more" wx:if="{{noMore && list.length}}">没有更多了</view>
</view>
