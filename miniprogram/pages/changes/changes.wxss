@import "../../app.wxss";

/* 趋势图 canvas 容器 */
.card canvas {
  width: 100%;
  height: 220px;
  margin-top: 8px;
}

/* 变化卡片 */
.change-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.change-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 600;
}

.change-tag.new-sale {
  background: #fff1f0;
  color: #FF4D4F;
}

.change-tag.status-change {
  background: #f0f5ff;
  color: #1989FA;
}

.change-house {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin: 12rpx 0 8rpx 0;
}

.change-detail {
  font-size: 24rpx;
  color: #666;
}

.text-gray {
  color: #999;
}
