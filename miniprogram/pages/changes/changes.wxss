@import "../../app.wxss";

/* 趋势图 canvas 容器 */
.card canvas {
  width: 100%;
  height: 220px;
  margin-top: 8px;
}

/* 变化卡片 */
.change-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.change-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 600;
}

.change-tag.new-sale {
  background: #fff1f0;
  color: #FF4D4F;
}

.change-tag.status-change {
  background: #f0f5ff;
  color: #1989FA;
}

.change-house {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin: 12rpx 0 8rpx 0;
}

.change-detail {
  font-size: 24rpx;
  color: #666;
}

.text-gray {
  color: #999;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.filter-tab {
  font-size: 12px;
  padding: 5px 14px;
  border-radius: 14px;
  background: #f5f5f5;
  color: #666;
}

.filter-tab.active {
  background: #E8F2FF;
  color: #1989FA;
  font-weight: 500;
}

  .sort-btn {
    margin-left: auto;
    font-size: 12px;
    padding: 5px 12px;
    border-radius: 14px;
    background: #f5f5f5;
    color: #666;
  }

  /* 按项目筛选栏 */
  .filter-project-bar {
    padding: 8px 16px;
    background: #fff;
    border-bottom: 1px solid #f0f0f0;
  }
