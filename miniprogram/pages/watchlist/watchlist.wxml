<view class="container">
  <view class="flex-between" style="margin-bottom:12px;">
    <view style="font-size:16px;font-weight:600;">关注楼盘 ({{list.length}})</view>
    <view class="btn btn-primary" bindtap="showAdd">+ 添加</view>
  </view>

  <!-- 关注列表 -->
  <block wx:for="{{list}}" wx:key="id">
    <view class="project-card" bindtap="goDetail" data-id="{{item.project_id}}">
      <view class="card-top">
        <view class="project-name">{{item.name || '未知楼盘'}}</view>
        <view class="project-arrow">›</view>
      </view>
      <view class="project-meta">{{item.notes || ''}}</view>
      <view class="project-stats" wx:if="{{item.showStats}}">
        <text class="stat-green">{{item.total_units}}套</text>
        <text class="stat-red">已售{{item.sold_units}}套</text>
        <text class="stat-rate">{{item.rate}}</text>
        <text class="stat-price" wx:if="{{item.avgPriceText}}">{{item.avgPriceText}}</text>
      </view>
    </view>
  </block>

  <view class="empty" wx:if="{{!list.length}}">
    <view>暂无关注楼盘</view>
    <view style="font-size:12px;color:#bbb;margin-top:4px;">点击「+ 添加」关注楼盘</view>
  </view>

  <!-- 添加关注弹窗 -->
  <view wx:if="{{showAdd}}" class="modal-overlay">
    <view class="modal-content">
      <view style="font-size:16px;font-weight:600;margin-bottom:16px;">
        {{selectedProject ? '确认添加' : '添加关注'}}
      </view>

      <view wx:if="{{selectedProject}}" style="background:#E8F5E9;padding:10px 14px;border-radius:8px;margin-bottom:12px;">
        <view style="font-weight:500;">{{selectedProject.name}}</view>
        <view wx:if="{{selectedProject.district}}" style="font-size:12px;color:#666;margin-top:2px;">{{selectedProject.district}}</view>
        <view style="font-size:12px;color:#999;margin-top:4px;" bindtap="clearSelection">✕ 重新选择</view>
      </view>

      <view wx:if="{{!selectedProject}}">
        <!-- 区域筛选 -->
        <view class="filter-row">
          <picker range="{{districtOptions}}" value="{{selectedDistrictIndex}}" bindchange="onDistrictPickerChange">
            <view class="district-picker">
              {{districtOptions[selectedDistrictIndex]}} ▼
            </view>
          </picker>
          <view class="filter-count" wx:if="{{!loadingProjects}}">共 {{filteredProjects.length}} 个楼盘</view>
        </view>

        <view wx:if="{{loadingProjects}}" style="text-align:center;padding:20px;color:#999;">加载中...</view>

        <block wx:if="{{filteredProjects.length > 0}}">
          <scroll-view scroll-y class="project-list" enhanced show-scrollbar>
            <view wx:for="{{filteredProjects}}" wx:key="project_id"
                  bindtap="selectProject" data-index="{{index}}"
                  class="project-item">
              <view class="item-name">{{item.name}}</view>
              <view class="item-meta">
                <text wx:if="{{item.district}}" class="item-district">{{item.district}}</text>
                <text>{{item.building_count || 0}}栋 · {{item.total_houses || 0}}套</text>
                <text wx:if="{{item.sold_rate}}" class="item-rate">去化 {{item.sold_rate}}</text>
              </view>
            </view>
          </scroll-view>
        </block>

        <view wx:elif="{{!loadingProjects}}" style="text-align:center;padding:20px;color:#999;">
          <view>该区域暂无可添加楼盘</view>
        </view>
      </view>

      <view wx:if="{{selectedProject}}" style="margin-top:12px;">
        <view style="font-size:13px;color:#999;margin-bottom:4px;">备注（可选）</view>
        <input placeholder="例如：重点关注三居室" value="{{form.note}}" bindinput="onNoteInput"
          style="padding:8px;border:1px solid #eee;border-radius:8px;width:100%;box-sizing:border-box;" />
      </view>

      <view style="display:flex;gap:12px;margin-top:16px;">
        <view class="btn" style="flex:1;background:#eee;color:#333;" bindtap="hideAdd">取消</view>
        <view class="btn btn-primary" style="flex:1;" bindtap="submitAdd">确定</view>
      </view>
    </view>
  </view>
</view>
