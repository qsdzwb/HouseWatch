@import "../../app.wxss";

/* 筛选行：下拉 + 计数 */
.filter-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

/* 区域下拉选择器 */
.district-picker {
  font-size: 13px;
  color: #333;
  background: #f5f5f5;
  padding: 8px 12px;
  border-radius: 8px;
  border: 1px solid #eee;
  white-space: nowrap;
  display: inline-block;
}

.filter-count {
  font-size: 12px;
  color: #999;
}

/* 弹窗遮罩 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 80px;
}

.modal-content {
  background: #fff;
  width: 90%;
  border-radius: 14px;
  padding: 20px;
  max-height: 70vh;
  overflow: hidden;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 楼盘列表 */
.project-list {
  max-height: 280px;
  border: 1px solid #f0f0f0;
  border-radius: 8px;
  background: #fafafa;
}

.project-item {
  padding: 12px 14px;
  border-bottom: 1px solid #f0f0f0;
  transition: background 0.2s;
  background: #fff;
}

.project-item:last-child {
  border-bottom: none;
}

.project-item:active {
  background: #f5f5f5;
}

.item-name {
  font-weight: 500;
  font-size: 14px;
  color: #333;
}

.item-meta {
  font-size: 12px;
  color: #999;
  margin-top: 4px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.item-district {
  color: #1976D2;
  background: #E3F2FD;
  padding: 0 6px;
  border-radius: 3px;
}

.item-rate {
  color: #FF6600;
}

/* 均价标签 */
.stat-price {
  color: #FF6B35;
  font-weight: 600;
  margin-left: auto;
}
