@import "../../app.wxss";

/* 设置页表单 */
.add-form {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 1px 3px rgba(0,0,0,.06);
}
.form-item {
  margin-bottom: 12px;
}
.form-item label {
  font-size: 13px;
  color: #666;
  display: block;
  margin-bottom: 4px;
}
.picker-text {
  border: 1px solid #eee;
  border-radius: 8px;
  padding: 8px 12px;
  font-size: 14px;
  color: #333;
  background: #fafafa;
}
.picker-text:active {
  background: #f0f0f0;
}
