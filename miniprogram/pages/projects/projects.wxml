<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索楼盘名称..." value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search"/>
    <view class="search-btn" bindtap="onSearch" wx:if="{{keyword}}">搜索</view>
    <view class="search-clear" bindtap="onClearSearch" wx:if="{{keyword}}">✕</view>
  </view>

  <!-- 排序标签 -->
  <view class="filter-row">
    <view class="filter-tag {{sortBy === 'total_houses' ? 'active' : ''}}" bindtap="onSort" data-field="total_houses">
      房源数 {{sortBy === 'total_houses' ? (sortOrder === 'desc' ? '↓' : '↑') : ''}}
    </view>
    <view class="filter-tag {{sortBy === 'sold_rate' ? 'active' : ''}}" bindtap="onSort" data-field="sold_rate">
      去化率 {{sortBy === 'sold_rate' ? (sortOrder === 'desc' ? '↓' : '↑') : ''}}
    </view>
    <view class="filter-tag {{sortBy === 'building_count' ? 'active' : ''}}" bindtap="onSort" data-field="building_count">
      楼栋数 {{sortBy === 'building_count' ? (sortOrder === 'desc' ? '↓' : '↑') : ''}}
    </view>
  </view>

  <!-- 楼盘列表 -->
  <block wx:for="{{list}}" wx:key="project_id">
    <view class="project-card" bindtap="goDetail" data-id="{{item.project_id}}">
      <view class="card-top">
        <view class="project-name">{{item.name}}</view>
        <view class="project-arrow">›</view>
      </view>
      <view class="project-meta">
        <text wx:if="{{item.district}}">{{item.district}} · </text>
        <text>{{item.building_count || 0}}栋 · {{item.total_houses || 0}}套</text>
        <text wx:if="{{item.developer}}" class="project-dev"> · {{item.developer}}</text>
      </view>
      <view class="project-stats">
        <text class="stat-item stat-green">可售 {{item.available_houses || 0}}</text>
        <text class="stat-item stat-red">已售 {{item.sold_houses || 0}}</text>
        <text class="stat-item stat-rate">{{item.sold_rate || '0.0%'}}</text>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!list.length && !loading}}">
    <view class="empty-icon">{{error ? '⚠️' : '📋'}}</view>
    <view>{{error || '暂无楼盘数据'}}</view>
    <view class="text-gray" style="font-size:12px;margin-top:4px;" wx:if="{{!error}}">请先添加关注项目</view>
    <view class="retry-btn" bindtap="onPullDownRefresh" wx:if="{{error}}" style="margin-top:12px;color:#1989FA;">点击重试</view>
  </view>

  <!-- 加载状态 -->
  <view class="load-more" wx:if="{{loading}}">加载中...</view>
  <view class="load-more" wx:if="{{noMore && list.length}}">— 没有更多了 —</view>
</view>
