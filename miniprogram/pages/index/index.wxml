<view class="container">
  <!-- 今日概览 -->
  <view class="card">
    <view class="card-title">今日概览</view>
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{today.newSales || 0}}</view>
        <view class="stat-label">今日成交(套)</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{today.avgPriceDisplay || '-'}}</view>
        <view class="stat-label">今日均价</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{overview.totalProjects || 0}}</view>
        <view class="stat-label">监测楼盘</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{overview.soldRate || '0%'}}</view>
        <view class="stat-label">整体去化率</view>
      </view>
    </view>
  </view>

  <!-- 价格趋势简报 -->
  <view class="card" wx:if="{{priceBrief}}">
    <view class="card-title">价格趋势简报</view>
    <view class="brief-header">
      <view class="brief-trend brief-trend-{{priceBrief.trend}}">{{priceBrief.trendText}}</view>
    </view>
    <view class="brief-stats" wx:if="{{priceBrief.avgPrice7d}}">
      <view class="brief-stat">
        <view class="brief-stat-label">近7天均价</view>
        <view class="brief-stat-value">{{priceBrief.avgPrice7dDisplay}}</view>
      </view>
      <view class="brief-stat" wx:if="{{priceBrief.avgPrice30d}}">
        <view class="brief-stat-label">近30天均价</view>
        <view class="brief-stat-value">{{priceBrief.avgPrice30dDisplay}}</view>
      </view>
    </view>
    <view class="brief-hot" wx:if="{{priceBrief.hotProjects.length}}">
      <view class="brief-hot-title">近期成交活跃楼盘</view>
      <view class="brief-hot-list">
        <view class="brief-hot-item" wx:for="{{priceBrief.hotProjects}}" wx:key="project_id">
          <text class="brief-hot-rank">{{index + 1}}</text>
          <text class="brief-hot-name">{{item.project_name}}</text>
          <text class="brief-hot-count">{{item.salesCount}}套</text>
          <text class="brief-hot-price">{{item.avgPriceDisplay}}</text>
        </view>
      </view>
    </view>
    <view class="brief-summary">{{priceBrief.summary}}</view>
  </view>

  <!-- 房源概况 -->
  <view class="card">
    <view class="card-title">房源概况</view>
    <view class="flex-between">
      <view>总房源: <text style="font-weight:600;">{{overview.totalHouses || 0}}</text> 套</view>
      <view>可售: <text class="text-green" style="font-weight:600;">{{overview.availableHouses || 0}}</text> 套</view>
      <view>已售: <text class="text-red" style="font-weight:600;">{{overview.soldHouses || 0}}</text> 套</view>
    </view>
  </view>

  <!-- 近7日成交趋势 -->
  <view class="card" wx:if="{{weeklyTrend.dates && weeklyTrend.dates.length}}">
    <view class="card-title">近7日成交趋势</view>
    <view class="trend-bar">
      <block wx:for="{{weeklyTrend.dates}}" wx:key="index">
        <view class="trend-col" style="height:{{weeklyTrend.counts[index] / weeklyTrend.max * 100}}%"></view>
      </block>
    </view>
    <view style="display:flex;justify-content:space-around;margin-top:4px;">
      <block wx:for="{{weeklyTrend.dates}}" wx:key="index"><view class="trend-label">{{item}}</view></block>
    </view>
    <view style="display:flex;justify-content:space-around;">
      <block wx:for="{{weeklyTrend.counts}}" wx:key="index"><view style="font-size:10px;color:#666;">{{item}}</view></block>
    </view>
  </view>

  <!-- 最后更新 -->
  <view class="text-gray" style="text-align:center;padding:16px;font-size:12px;" wx:if="{{lastCrawl}}">
    最后更新: {{lastCrawl.crawl_date || ''}}
  </view>
</view>
