<view class="container" wx:if="{{project.project_id}}">
  <!-- 标题 + 关注 -->
  <view class="card">
    <view class="flex-between">
      <view class="detail-title">{{project.display_name ? project.display_name + '(' + project.name + ')' : project.name}}</view>
      <view class="btn {{isWatched ? 'btn-outline' : 'btn-primary'}}" bindtap="toggleWatch">
        {{isWatched ? '已关注' : '+ 关注'}}
      </view>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="card">
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{stats.totalUnits || 0}}</view>
        <view class="stat-label">总房源</view>
      </view>
      <view class="stat-item">
        <view class="stat-value text-green">{{stats.available || 0}}</view>
        <view class="stat-label">可售</view>
      </view>
      <view class="stat-item">
        <view class="stat-value text-red">{{stats.sold || 0}}</view>
        <view class="stat-label">已售</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.soldRate || '0'}}%</view>
        <view class="stat-label">去化率</view>
      </view>
    </view>
    <!-- 各预售证均价（分别展示，不合并） -->
    <view wx:if="{{stats.permit_prices.length > 0}}" class="price-rows">
      <view wx:for="{{stats.permit_prices}}" wx:key="project_id" class="price-row">
        <text class="price-label">{{item.display_name || item.permit_no || item.project_id}}</text>
        <text class="price-value">{{item.avg_price}} 元/㎡（已售{{item.signed_count}}套）</text>
      </view>
    </view>
  </view>

  <!-- 价格走势图 -->
  <view class="card" wx:if="{{hasTrend}}">
    <view class="card-title">近30天成交均价走势</view>
    <view wx:if="{{priceInsight}}" class="insight-box {{priceInsight.indexOf('低位') >= 0 ? 'insight-good' : (priceInsight.indexOf('高位') >= 0 ? 'insight-warn' : 'insight-info')}}">
      {{priceInsight}}
    </view>
    <view wx:if="{{priceTip}}" class="price-tip price-tip-{{priceTipType}}">
      {{priceTip}}
    </view>
    <canvas canvas-id="priceChart" id="priceChart"
            style="width:100%;height:200px;"></canvas>
  </view>
  <view class="card" wx:elif="{{!buildings.length}}">
    <view class="empty">暂无价格走势数据</view>
  </view>

  <!-- 楼栋列表 -->
  <view class="card-title" style="padding:0 16px;">楼栋详情</view>
  <block wx:for="{{buildings}}" wx:key="building_id">
    <view class="building-card" bindtap="goBuilding" data-id="{{item.building_id}}">
      <view class="flex-between">
        <view>
          <view class="building-name">{{item.building_name}}</view>
          <view class="building-info">
            {{item.total_houses || 0}}套 · 已售{{item.sold_count || 0}}套
            <text wx:if="{{item.price_display}}" style="color:#FF6600;margin-left:4px;">{{item.price_display}}</text>
          </view>
        </view>
        <view class="project-arrow">›</view>
      </view>
      <view class="status-bar">
        <view class="status-segment seg-green" style="flex:{{item.flex_avail}};"></view>
        <view class="status-segment seg-red" style="flex:{{item.flex_sold}};"></view>
        <view class="status-segment seg-orange" style="flex:{{item.flex_other}};"></view>
      </view>
    </view>
  </block>

  <view class="empty" wx:if="{{!buildings.length}}">暂无楼栋数据</view>
</view>

<view class="empty" wx:if="{{!project.project_id}}">加载中...</view>
