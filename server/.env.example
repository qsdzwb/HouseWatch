# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=bj_realestate

# 服务端口
PORT=3000

# 爬虫配置
CRAWL_BASE_URL=http://bjjs.zjw.beijing.gov.cn
CRAWL_PAGE_URL=http://bjjs.zjw.beijing.gov.cn/eportal/ui
CRAWL_CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# 爬取模式: test（仅样本项目）| production（全量）
CRAWL_MODE=test

# 日志级别: debug | info | warn | error
LOG_LEVEL=info
